# VirtualHost WordPress - Généré par Ansible
# Reproduit exactement le bloc du script original

<VirtualHost *:{{ wp_server_port }}>
    ServerAdmin {{ wp_server_admin }}
    DocumentRoot {{ wp_wordpress_install_dir }}

    <Directory {{ wp_wordpress_install_dir }}>
        AllowOverride All
    </Directory>

{% if ansible_os_family == "Debian" %}
    ErrorLog ${APACHE_LOG_DIR}/error.log
    CustomLog ${APACHE_LOG_DIR}/access.log combined
{% else %}
    ErrorLog /var/log/httpd/wordpress_error.log
    CustomLog /var/log/httpd/wordpress_access.log combined
{% endif %}
</VirtualHost>
